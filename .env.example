# AIRED — environment variables.
# Copy to .env.local for local dev, and set the same values in Vercel.

# Public client credentials (safe to expose in the browser; guarded by RLS).
NEXT_PUBLIC_SUPABASE_URL=https://bfvgqvpoecakwintxhap.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_nQg2He1bEI0CBnGgxHyNrQ_-qfcM97X

# Phase 3 — public base URL for streamed audio served from R2 via CDN (Rule 6).
# No trailing slash. The Red Line player joins it with a work's hls_playlist_key.
# Swap to the custom domain (e.g. https://cdn.ai-red.io) later with no code change.
# NEXT_PUBLIC_ is inlined at build time, so changing it in Vercel needs a redeploy.
NEXT_PUBLIC_R2_PUBLIC_BASE=https://pub-xxxxxxxx.r2.dev

# Server-only secrets (CLAUDE.md §1.7) — never commit real values, never ship to
# the browser. Set these in .env.local locally and in Vercel (all environments).

# Phase 2 — REQUIRED to seal & declare volleys. AES-256-GCM key: 32 bytes, base64.
# Generate once:  openssl rand -base64 32
AIRED_VOLLEY_ENC_KEY=

# Later phases (added as the features that need them land):
# SUPABASE_SERVICE_ROLE_KEY=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
