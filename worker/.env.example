# AIRED transcoding worker — environment variables.
#
# Copy to .env (git-ignored) for local runs, or set these in Railway → the
# worker service → Variables. Values marked SECRET are env-only and must never
# be committed (CLAUDE.md §1.7). Values marked DEFAULT already have a baked-in
# default in src/config.js — set them only to override.

# --- Supabase (read the work row + download the master) ---------------------
# DEFAULT: the aired-platform project URL.
SUPABASE_URL=https://bfvgqvpoecakwintxhap.supabase.co
# SECRET, REQUIRED: service-role key — bypasses RLS to read any work row and
# sign a download URL for the private master. Server-only, never in client code.
SUPABASE_SERVICE_ROLE_KEY=
# DEFAULT: the private Supabase Storage bucket holding uploaded masters.
SUPABASE_MASTERS_BUCKET=masters

# --- Cloudflare R2 (store the master copy + the HLS rendition) --------------
# DEFAULT: the AIRED R2 account id and its S3 endpoint (R2_ENDPOINT defaults to
# https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com when unset).
R2_ACCOUNT_ID=da822c931d669d9e250ed67ab8fd7323
R2_ENDPOINT=https://da822c931d669d9e250ed67ab8fd7323.r2.cloudflarestorage.com
# SECRET, REQUIRED: an R2 API token's access key id + secret (S3-compatible).
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# DEFAULT: destination buckets. aired-masters = archival master copy;
# aired-hls = the served playlist + segments.
R2_MASTERS_BUCKET=aired-masters
R2_HLS_BUCKET=aired-hls

# --- This worker ------------------------------------------------------------
# SECRET, REQUIRED for the HTTP endpoint: callers must present this exact value
# as `Authorization: Bearer <secret>` (or `X-Transcode-Secret`). Generate one:
#   openssl rand -hex 32
# (Not needed for the `npm run transcode -- <id>` CLI form.)
TRANSCODE_SHARED_SECRET=

# DEFAULT (optional tuning): the HLS rendition.
AUDIO_BITRATE=192k
HLS_SEGMENT_SECONDS=6

# --- SHARE VIDEO (the downloadable Reels / TikTok clip per song) -------------
# DEFAULT: the app origin the worker fetches the burned-in still frame from
# (GET {APP_ORIGIN}/share/song/{id}/clip-frame/{orientation}). Same credits as
# the image cards. No trailing slash.
APP_ORIGIN=https://ai-red.io
# DEFAULT (optional tuning): the clip frame rate. The audio WINDOW (start +
# length) is per-song now — set in /manage and stored on the work row
# (clip_start_seconds / clip_length_seconds), then clamped by the worker — so it
# is no longer an env knob.
CLIP_FPS=30

# DEFAULT: HTTP port. Railway injects PORT automatically.
PORT=8080
